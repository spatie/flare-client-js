{
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces",
        "test": "npm run test --workspaces --if-present",
        "typescript": "npm run typescript --workspaces --if-present",
        "format": "prettier --write \"**/*.{js,json,vue,ts,tsx}\"",
        "prepare": "husky install",
        "release:js": "npm run release --workspace=packages/js",
        "release:react": "npm run release --workspace=packages/react",
        "release:vue": "npm run release --workspace=packages/vue",
        "release:vite": "npm run release --workspace=packages/vite"
    },
    "devDependencies": {
        "husky": "^8.0.3",
        "lint-staged": "^15.2.0",
        "prettier": "^3.3.3"
    },
    "lint-staged": {
        "*.{js,json,vue,ts,tsx}": "prettier --write"
    },
    "dependencies": {
        "@trivago/prettier-plugin-sort-imports": "^4.3.0"
    }
}
