{
    "private": true,
    "author": {
        "name": "Spatie",
        "email": "info@spatie.be"
    },
    "contributors": [
        "Adriaan Marain <adriaan@spatie.be>",
        "Alex Vanderbist <alex@spatie.be>",
        "Dries Heyninck <dries@spatie.be>",
        "Freek Van der Herten <freek@spatie.be>",
        "Sebastian De Deyne <sebastian@spatie.be>",
        "Sébastien Henau <seba@spatie.be>"
    ],
    "workspaces": [
        "packages/*",
        "playground",
        "playground-sveltekit"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "test": "npm run build && npm run test --workspaces --if-present",
        "typescript": "npm run typescript --workspaces --if-present",
        "playground": "npm run build --workspaces --if-present && npm run dev --workspace=playground",
        "playground:preview": "npm run build --workspaces --if-present && npm run preview --workspace=playground",
        "playground:sveltekit": "npm run build --workspaces --if-present && npm run dev --workspace=playground-sveltekit",
        "format": "oxfmt .",
        "lint": "oxlint",
        "prepare": "husky",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/node": "^25.3.0",
        "husky": "^9.0.0",
        "lint-staged": "^16.2.7",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "release-it": "^20.0.1"
    },
    "optionalDependencies": {
        "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.3"
    }
}
