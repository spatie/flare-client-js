{
    "private": true,
    "engines": {
        "node": ">=18"
    },
    "workspaces": [
        "packages/*",
        "playground"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "typescript": "npm run typescript --workspaces --if-present",
        "playground": "npm run build --workspaces --if-present && npm run dev --workspace=playground",
        "playground:preview": "npm run build --workspaces --if-present && npm run preview --workspace=playground",
        "format": "prettier --write \"**/*.{js,json,vue,ts,tsx}\"",
        "prepare": "husky",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.3.0",
        "husky": "^9.0.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.3.3",
        "release-it": "^20.0.1"
    },
    "optionalDependencies": {
        "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.3"
    }
}
