{
    "private": true,
    "engines": {
        "node": ">=18"
    },
    "workspaces": [
        "packages/*",
        "playground"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "typescript": "npm run typescript --workspaces --if-present",
        "playground": "npm run build --workspaces --if-present && npm run dev --workspace=playground",
        "format": "prettier --write \"**/*.{js,json,vue,ts,tsx}\"",
        "prepare": "husky"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.3.0",
        "husky": "^9.0.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.3.3"
    }
}
