{
    "name": "@flareapp/flare-api",
    "private": true,
    "version": "1.0.0",
    "description": "Shared Flare API client for sourcemap uploads (internal)",
    "license": "MIT",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsdown src/index.ts --format cjs,esm --dts --clean",
        "test": "vitest run",
        "typescript": "tsc --noEmit"
    },
    "devDependencies": {
        "tsdown": "^0.20.3",
        "typescript": "^5.7.0",
        "vitest": "^4.0.0"
    }
}
