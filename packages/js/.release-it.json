{
    "git": {
        "commitMessage": "Release @flareapp/js v${version}",
        "tagName": "@flareapp/js@${version}",
        "tagAnnotation": "Release @flareapp/js v${version}"
    },
    "github": {
        "release": false
    },
    "npm": {
        "publish": true
    },
    "hooks": {
        "before:init": ["npm run test", "npm run typescript"],
        "after:bump": "npm run build"
    }
}
