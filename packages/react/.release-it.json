{
    "git": {
        "tagName": "@flareapp/react@${version}",
        "tagAnnotation": "Release @flareapp/react@${version}",
        "commitMessage": "chore: release @flareapp/react@${version}",
        "requireBranch": "main",
        "requireCleanWorkingDir": true,
        "push": true
    },
    "npm": {
        "publish": true
    },
    "github": {
        "release": false
    },
    "hooks": {
        "before:release": "npm test --if-present"
    }
}
