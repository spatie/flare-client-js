# Copy to .env.local (git-ignored, auto-loaded by the Expo CLI) and fill in.

# Flare project key. Used at runtime (flare.light) AND to generate flare.json for the
# sourcemap upload. Required to send reports.
FLARE_API_KEY=

# Optional: override the report ingest endpoint (default is real Flare ingress).
# FLARE_INGEST_URL=https://ingress.flareapp.io/v1/errors

# Optional: tag reports (and the uploaded sourcemap) with a version. Set this to
# exercise the Babel inlining — reports then carry it as sourcemapVersionId. Clear the
# Metro cache (expo start -c) after changing it.
# FLARE_SOURCEMAP_VERSION=
